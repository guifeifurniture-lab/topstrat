# PayPal API Configuration
# ⚠️ 安全警告：此文件包含敏感信息，请勿提交到 Git 仓库
# 请将此文件添加到 .gitignore

# PayPal 生产环境凭证
# 获取方式：https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_production_client_id_here
PAYPAL_CLIENT_SECRET=your_production_client_secret_here

# PayPal Webhook ID
# 获取方式：在 PayPal Dashboard 创建 Webhook 后获取
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# 环境配置
PAYPAL_ENV=live
# PAYPAL_ENV=sandbox  # 沙盒测试时切换

# 沙盒环境凭证（可选）
PAYPAL_SANDBOX_CLIENT_ID=your_sandbox_client_id_here
PAYPAL_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret_here
PAYPAL_SANDBOX_WEBHOOK_ID=your_sandbox_webhook_id_here

# 服务器配置
SERVER_URL=https://yourdomain.com
WEBHOOK_URL=${SERVER_URL}/api/paypal/webhook

# 通知配置
ADMIN_EMAIL=bjd1129@gmail.com
NOTIFICATION_EMAIL=voxyz.developer@gmail.com
