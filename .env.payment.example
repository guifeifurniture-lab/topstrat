# 支付集成环境配置
# ⚠️ 安全警告：此文件包含敏感信息，请勿提交到 Git 仓库
# 请将此文件添加到 .gitignore

# ===========================================
# Lemon Squeezy 配置
# ===========================================
# 获取方式：https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=your_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here

# 产品 Variant ID
# 获取方式：在 Lemon Squeezy Dashboard -> Products -> 点击产品 -> Variants
LEMON_SQUEEZY_STARTER_VARIANT_ID=starter_variant_id_here
LEMON_SQUEEZY_PRO_VARIANT_ID=pro_variant_id_here

# ===========================================
# GitHub 配置（用于自动发送仓库邀请）
# ===========================================
# 获取方式：https://github.com/settings/tokens
# 需要权限：repo (Full control of private repositories)
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=voxyz
GITHUB_REPO=moushi-tiantuan

# ===========================================
# 服务器配置
# ===========================================
SERVER_URL=https://voxyz.com
CHECKOUT_SUCCESS_URL=${SERVER_URL}/vault?success=true
CHECKOUT_CANCEL_URL=${SERVER_URL}/vault?cancelled=true

# ===========================================
# 通知配置
# ===========================================
FROM_EMAIL=no-reply@voxyz.com
ADMIN_EMAIL=bjd1129@gmail.com
NOTIFICATION_EMAIL=voxyz.developer@gmail.com

# ===========================================
# PayPal 配置（备用支付）
# ===========================================
# 获取方式：https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here
PAYPAL_ENV=live
# PAYPAL_ENV=sandbox  # 沙盒测试时切换
